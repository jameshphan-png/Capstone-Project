        "    latency = f\"{elapsed:.2f}s\"\n",
        "    audit = _format_audit(result)\n",
        "    trace = _format_trace(result)\n",
        "\n",
        "    return history, history, route_info, latency, audit, trace, new_temp_pw_state, temp_display\n",
        "\n",
