      "source": [
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "#  MODEL CONTEXT PROTOCOL — In-Process Implementation\n",
        "#  Follows the MCP spec: https://modelcontextprotocol.io/docs/concepts/tools\n",
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "\n",
        "from typing import Callable\n",
        "\n",
        "def _utcnow() -> str:\n",
        "    \"\"\"Return a UTC ISO-8601 timestamp — deprecation-warning-free.\"\"\"\n",
        "    return dt.datetime.now(dt.timezone.utc).isoformat()\n",
        "\n",
        "# ── MCP Data Structures ───────────────────────────────────────────────────────\n",
        "\n",
        "class MCPToolDefinition(BaseModel):\n",
        "    name:        str\n",
        "    description: str\n",
        "    inputSchema: Dict[str, Any]\n",
        "\n",
        "class MCPToolCallRequest(BaseModel):\n",
        "    call_id:   str = Field(default_factory=lambda: str(uuid.uuid4())[:8])\n",
        "    method:    str = \"tools/call\"\n",
        "    tool_name: str\n",
        "    arguments: Dict[str, Any] = Field(default_factory=dict)\n",
        "    timestamp: str = Field(default_factory=_utcnow)\n",
        "\n",
        "class MCPContentBlock(BaseModel):\n",
        "    type: str = \"text\"\n",
        "    text: str\n",
        "\n",
        "class MCPToolResult(BaseModel):\n",
        "    call_id:   str\n",
        "    tool_name: str\n",
        "    content:   List[MCPContentBlock]\n",
        "    is_error:  bool = False\n",
        "    timestamp: str = Field(default_factory=_utcnow)\n",
        "\n",
        "    def text(self) -> str:\n",
        "        return \" \".join(b.text for b in self.content)\n",
        "\n",
        "\n",
        "# ── MCP Tool Registry ─────────────────────────────────────────────────────────\n",
        "\n",
        "class MCPToolRegistry:\n",
        "    \"\"\"\n",
        "    Lightweight in-process MCP server.\n",
        "\n",
        "    Lifecycle:\n",
        "      1.  register_tool()  — publish a tool with its JSON schema\n",
        "      2.  initialize()     — agent handshake; returns capability list\n",
        "      3.  list_tools()     — returns all registered MCPToolDefinitions\n",
        "      4.  call_tool()      — validate input, execute, wrap in MCP envelope\n",
        "      5.  get_audit_log()  — returns full call history for observability\n",
        "    \"\"\"\n",
        "\n",
        "    def __init__(self):\n",
        "        self._tools:     Dict[str, MCPToolDefinition] = {}\n",
        "        self._handlers:  Dict[str, Callable]          = {}\n",
        "        self._audit_log: List[Dict[str, Any]]         = []\n",
        "\n",
        "    def register_tool(self, name: str, description: str,\n",
        "                      input_schema: Dict[str, Any], handler: Callable) -> None:\n",
        "        self._tools[name]    = MCPToolDefinition(\n",
        "            name=name, description=description, inputSchema=input_schema)\n",
        "        self._handlers[name] = handler\n",
        "\n",
        "    def initialize(self) -> Dict[str, Any]:\n",
        "        return {\n",
        "            \"protocolVersion\": \"2024-11-05\",\n",
        "            \"capabilities\":    {\"tools\": {\"listChanged\": False}},\n",
        "            \"serverInfo\":      {\"name\": \"IT-Helpdesk-MCP\", \"version\": \"1.0.0\"},\n",
        "            \"tools\":           [t.model_dump() for t in self._tools.values()],\n",
        "        }\n",
        "\n",
        "    def list_tools(self) -> List[MCPToolDefinition]:\n",
        "        return list(self._tools.values())\n",
        "\n",
        "    def call_tool(self, request: MCPToolCallRequest) -> MCPToolResult:\n",
        "        handler = self._handlers.get(request.tool_name)\n",
        "        if handler is None:\n",
        "            result = MCPToolResult(\n",
        "                call_id=request.call_id, tool_name=request.tool_name,\n",
        "                content=[MCPContentBlock(text=f\"Unknown tool: {request.tool_name}\")],\n",
        "                is_error=True,\n",
        "            )\n",
        "        else:\n",
        "            try:\n",
        "                raw    = handler(**request.arguments)\n",
        "                result = MCPToolResult(\n",
        "                    call_id=request.call_id, tool_name=request.tool_name,\n",
        "                    content=[MCPContentBlock(text=json.dumps(raw))], is_error=False,\n",
        "                )\n",
        "            except Exception as exc:\n",
        "                result = MCPToolResult(\n",
        "                    call_id=request.call_id, tool_name=request.tool_name,\n",
        "                    content=[MCPContentBlock(text=str(exc))], is_error=True,\n",
        "                )\n",
        "\n",
        "        self._audit_log.append({\n",
        "            \"call_id\":   request.call_id,\n",
        "            \"tool\":      request.tool_name,\n",
        "            \"arguments\": request.arguments,\n",
        "            \"is_error\":  result.is_error,\n",
        "            \"response\":  result.text(),\n",
        "            \"ts\":        request.timestamp,\n",
        "        })\n",
        "        return result\n",
        "\n",
        "    def get_audit_log(self) -> List[Dict[str, Any]]:\n",
        "        return list(self._audit_log)\n",
        "\n",
        "    def print_audit_log(self) -> None:\n",
        "        print()\n",
        "        print(\"MCP Audit Log\")\n",
        "        print(\"-\" * 60)\n",
        "        for entry in self._audit_log:\n",
        "            status = \"OK   \" if not entry[\"is_error\"] else \"ERROR\"\n",
        "            ts     = entry[\"ts\"][:19].replace(\"T\", \" \")\n",
        "            print(f\"  [{status}]  {ts}  {entry['tool']}({entry['arguments']})\")\n",
        "            print(f\"           => {entry['response'][:90]}\")\n",
        "        print(\"-\" * 60)\n",
        "\n",
        "\n",
        "print(\"✅ MCP Tool Registry class defined.\")\n"
      ],
