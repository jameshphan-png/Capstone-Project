        "---\n",
        "## Section 3a — Intake Agent\n",
        "\n",
        "**Role:** The entry point for every user request.\n",
        "Classifies the query into a `top_level` routing category and a fine-grained `label`.\n",
        "Uses an OpenAI LLM (when available) or a deterministic rule-based fallback.\n",
        "\n",
        "**Outputs:** Populated `Intent` object written to `GraphState.intent`.\n"
      ],
      "id": "AULjSP_hyonG"
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "j0W2SNWdyonG",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "ca52bfe6-ef4d-4f82-bff5-6090da7c91e6"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "✅ Intake Agent defined.\n"
          ]
        }
      ],
      "source": [
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "#  INTAKE AGENT — Classification & Routing\n",
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "\n",
        "if USE_OPENAI or USE_FREE_LLM:\n",
        "    from pydantic import BaseModel as _PydanticBase\n",
        "    class _IntakeSchema(_PydanticBase):\n",
        "        top_level:  Literal[\"knowledge\", \"workflow\", \"escalation\"]\n",
        "        label:      Literal[\"forgot_password\",\"account_locked\",\"mfa_help\",\"policy_question\",\"escalate\"]\n",
        "        confidence: float\n",
        "\n",
        "\n",
        "def _mock_classify(user_query: str, forgot_password_selected: bool) -> Intent:\n",
        "    \"\"\"Rule-based intent classifier (used when OpenAI is not configured).\"\"\"\n",
        "    q = user_query.lower().strip()\n",
        "\n",
        "    if forgot_password_selected or (\"forgot\" in q and \"password\" in q):\n",
        "        return Intent(top_level=\"workflow\", label=\"forgot_password\", confidence=0.99)\n",
        "\n",
        "    if \"locked\" in q or \"lockout\" in q:\n",
        "        if any(kw in q for kw in [\"how long\", \"what\", \"when\", \"why\", \"policy\"]):\n",
        "            return Intent(top_level=\"knowledge\", label=\"policy_question\", confidence=0.92)\n",
        "        return Intent(top_level=\"workflow\", label=\"account_locked\", confidence=0.95)\n",
        "\n",
        "    if any(kw in q for kw in [\"mfa\", \"authenticator\", \"multi-factor\", \"second factor\"]):\n",
        "        return Intent(top_level=\"knowledge\", label=\"mfa_help\", confidence=0.95)\n",
        "\n",
        "    if any(kw in q for kw in [\"policy\", \"manual\", \"how\", \"what\", \"when\", \"help\",\n",
        "                              \"temporary password\", \"password rule\"]):\n",
        "        return Intent(top_level=\"knowledge\", label=\"policy_question\", confidence=0.90)\n",
        "\n",
        "    # Unclear or out-of-scope requests go straight to escalation.\n",
        "    return Intent(top_level=\"escalation\", label=\"escalate\", confidence=0.70)\n",
        "\n",
        "\n",
        "def intake_node(state: GraphState) -> Dict[str, Any]:\n",
        "    \"\"\"\n",
        "    INTAKE AGENT — Classifies the user request and determines the routing path.\n",
        "\n",
        "    Collaboration: Writes 'intent' and 'trace' back to GraphState.\n",
        "    Next node: knowledge | workflow | escalation  (determined by route_from_intake)\n",
        "    \"\"\"\n",
        "    if USE_OPENAI:\n",
        "        prompt = ChatPromptTemplate.from_template(\n",
        "            \"\"\"You are an IT-support intake agent.\n",
        "Classify the request:\n",
        "  top_level : knowledge | workflow | escalation\n",
        "  label     : forgot_password | account_locked | mfa_help | policy_question | escalate\n",
        "  confidence: 0.0–1.0\n",
        "\n",
        "Rules:\n",
        "- forgot/reset password        → workflow / forgot_password\n",
        "- account locked               → workflow / account_locked\n",
        "- MFA / lost device            → knowledge / mfa_help\n",
        "- policy / rule / process Q    → knowledge / policy_question\n",
        "- unclear / other / out of scope → escalation / escalate\n",
        "\n",
        "User request: {user_query}\"\"\"\n",
        "        )\n",
        "        chain  = prompt | llm.with_structured_output(_IntakeSchema)\n",
        "        result = chain.invoke({\"user_query\": state.user_query})\n",
        "        intent = Intent(top_level=result.top_level, label=result.label,\n",
        "                        confidence=result.confidence)\n",
        "    else:\n",
        "        intent = _mock_classify(state.user_query, state.forgot_password_selected)\n",
        "\n",
        "    return {\n",
        "        \"intent\": intent,\n",
        "        \"trace\":  state.trace + [\n",
        "            f\"[intake] {intent.top_level}/{intent.label} conf={intent.confidence:.2f}\"\n",
        "        ],\n",
        "    }\n",
        "\n",
        "\n",
        "print(\"✅ Intake Agent defined.\")\n"
      ],
      "id": "j0W2SNWdyonG"
    },
