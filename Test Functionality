        "\n",
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "#  SECTION 6 — GRADIO WEB UI\n",
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "\n",
        "import gradio as gr\n",
        "import time\n",
        "import re\n",
        "\n",
        "# ── UI helpers ────────────────────────────────────────────────────────────────\n",
        "# These helper functions keep the Gradio event code readable and make the\n",
        "# interface behavior easier to explain during the demo.\n",
        "\n",
        "def _format_audit(result) -> str:\n",
        "    \"\"\"Convert MCP tool-call logs into a readable multiline audit panel.\"\"\"\n",
        "    if not result.mcp_calls:\n",
        "        return \"No MCP tools called.\"\n",
        "    lines = []\n",
        "    for c in result.mcp_calls:\n",
        "        icon = \"✅\" if c.success else \"❌\"\n",
        "        lines.append(f\"{icon}  {c.tool_name}  (ID: {c.call_id})\\n    {c.summary[:80]}\")\n",
        "    return \"\\n\\n\".join(lines)\n",
        "\n",
        "\n",
        "def _format_trace(result) -> str:\n",
        "    \"\"\"Show the LangGraph route as a readable step-by-step trace.\"\"\"\n",
        "    return \"\\n\".join(f\"→ {step}\" for step in result.trace) or \"No trace available.\"\n",
        "\n",
        "\n",
        "def _looks_like_password_reset_request(message: str) -> bool:\n",
        "    \"\"\"Detect requests that should require identity verification before reset.\"\"\"\n",
        "    q = (message or \"\").lower()\n",
        "    reset_patterns = [\n",
        "        r\"forgot.*password\",\n",
        "        r\"reset.*password\",\n",
        "        r\"temporary password\",\n",
        "        r\"temp password\",\n",
        "        r\"assign.*password\",\n",
        "        r\"issue.*password\",\n",
        "        r\"new password\",\n",
        "        r\"can.t log in.*password\",\n",
        "    ]\n",
        "    return any(re.search(pattern, q) for pattern in reset_patterns)\n",
        "\n",
        "\n",
        "def verify_identity(username, employee_id, email, factor, passcode):\n",
        "    \"\"\"\n",
        "    Security gate for the Helpdesk Chat password-reset workflow.\n",
        "\n",
        "    The demo keeps the checks simple and readable for the audience:\n",
        "    - username must be present\n",
        "    - employee ID must be numeric and 6 digits long\n",
        "    - company email must look valid\n",
        "    - a second factor must be selected\n",
        "    - a one-time code must be 6 digits\n",
        "\n",
        "    When all checks pass, the returned state allows the chat to issue a\n",
        "    temporary password on a later password-reset request.\n",
        "    \"\"\"\n",
        "    username = (username or \"\").strip()\n",
        "    employee_id = (employee_id or \"\").strip()\n",
        "    email = (email or \"\").strip()\n",
        "    factor = (factor or \"\").strip()\n",
        "    passcode = (passcode or \"\").strip()\n",
        "\n",
        "    errors = []\n",
        "    if not username:\n",
        "        errors.append(\"enter a username\")\n",
        "    if not re.fullmatch(r\"\\d{6}\", employee_id):\n",
        "        errors.append(\"use a 6-digit employee ID\")\n",
        "    if not re.fullmatch(r\"[^@\\s]+@[^@\\s]+\\.[^@\\s]+\", email):\n",
        "        errors.append(\"enter a valid company email\")\n",
        "    if factor not in {\"Authenticator App\", \"SMS Code\", \"Hardware Token\"}:\n",
        "        errors.append(\"choose a supported second factor\")\n",
        "    if not re.fullmatch(r\"\\d{6}\", passcode):\n",
        "        errors.append(\"enter a 6-digit verification code\")\n",
        "\n",
        "    if errors:\n",
        "        return (\n",
        "            False,\n",
        "            \"⛔ Identity verification incomplete. Please \" + \", \".join(errors) + \".\",\n",
        "            '<div class=\"verify-status warning\">Verification required before IT can issue a temporary password.</div>',\n",
        "        )\n",
        "\n",
        "    return (\n",
        "        True,\n",
        "        f\"✅ Identity verified for {username}. IT can now continue with password-reset assistance.\",\n",
        "        '<div class=\"verify-status success\">Identity check complete — temporary-password requests are now enabled for this session.</div>',\n",
        "    )\n",
        "\n",
        "\n",
        "def clear_verification_panel():\n",
        "    \"\"\"Reset the verification state when the user wants to start over.\"\"\"\n",
        "    return (\n",
        "        False,\n",
        "        \"Verification not started.\",\n",
