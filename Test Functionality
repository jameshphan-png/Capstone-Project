        }
      ],
      "source": [
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "#  TOOL HANDLERS — pure Python functions, wrapped by MCP\n",
        "#  These simulate backend IT automation services.\n",
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "\n",
        "def _handler_reset_password(user_id: str) -> Dict[str, Any]:\n",
        "    \"\"\"Resets the user's password and returns a temporary credential.\"\"\"\n",
        "    if not user_id:\n",
        "        raise ValueError(\"user_id is required.\")\n",
        "    if user_id.lower().startswith(\"fail_reset\"):\n",
        "        raise RuntimeError(\"Password reset service is currently unavailable.\")\n",
        "    return {\"status\": \"success\", \"temp_password\": TEMP_PASSWORD, \"user_id\": user_id}\n",
        "\n",
        "\n",
        "def _handler_unlock_account(user_id: str) -> Dict[str, Any]:\n",
        "    \"\"\"Unlocks a locked account, allowing the user to attempt login again.\"\"\"\n",
        "    if not user_id:\n",
        "        raise ValueError(\"user_id is required.\")\n",
        "    if user_id.lower().startswith(\"fail_unlock\"):\n",
        "        raise RuntimeError(\"Account unlock service is currently unavailable.\")\n",
        "    return {\"status\": \"success\", \"account_status\": \"unlocked\", \"user_id\": user_id}\n",
        "\n",
        "\n",
        "def _handler_create_ticket(summary: str, description: str) -> Dict[str, Any]:\n",
        "    \"\"\"Opens an IT support ticket and returns the ticket ID.\"\"\"\n",
        "    if not summary.strip() or not description.strip():\n",
        "        raise ValueError(\"Both summary and description are required.\")\n",
        "    ticket_id = f\"INC-{abs(hash((summary, description))) % 100_000:05d}\"\n",
        "    return {\n",
        "        \"status\":      \"success\",\n",
        "        \"ticket_id\":   ticket_id,\n",
        "        \"summary\":     summary,\n",
        "        \"created_at\":  dt.datetime.now(dt.timezone.utc).isoformat(),\n",
        "    }\n",
        "\n",
        "\n",
        "def _handler_log_analysis(log_type: str, user_id: str) -> Dict[str, Any]:\n",
        "    \"\"\"\n",
        "    Simulates querying an IT audit log for a specific user and log type.\n",
        "    Supported log_types: login_failures, account_changes, mfa_events\n",
        "    \"\"\"\n",
        "    mock_logs = {\n",
        "        \"login_failures\": [\n",
        "            {\"ts\": \"2026-04-24T08:01:00Z\", \"user\": user_id, \"event\": \"LOGIN_FAILED\", \"ip\": \"10.0.0.12\"},\n",
        "            {\"ts\": \"2026-04-24T08:02:30Z\", \"user\": user_id, \"event\": \"LOGIN_FAILED\", \"ip\": \"10.0.0.12\"},\n",
        "            {\"ts\": \"2026-04-24T08:03:10Z\", \"user\": user_id, \"event\": \"ACCOUNT_LOCKED\", \"ip\": \"10.0.0.12\"},\n",
        "        ],\n",
        "        \"account_changes\": [\n",
        "            {\"ts\": \"2026-04-24T09:15:00Z\", \"user\": user_id, \"event\": \"PASSWORD_RESET\", \"actor\": \"self-service\"},\n",
        "        ],\n",
        "        \"mfa_events\": [\n",
        "            {\"ts\": \"2026-04-24T09:20:00Z\", \"user\": user_id, \"event\": \"MFA_ENROLLED\",   \"device\": \"AuthApp\"},\n",
        "        ],\n",
        "    }\n",
        "    entries = mock_logs.get(log_type, [])\n",
        "    return {\"log_type\": log_type, \"user_id\": user_id, \"entries\": entries, \"count\": len(entries)}\n",
        "\n",
        "\n",
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "#  REGISTER TOOLS WITH THE MCP SERVER\n",
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "\n",
        "mcp_server = MCPToolRegistry()\n",
        "\n",
        "mcp_server.register_tool(\n",
        "    name        = \"reset_password\",\n",
        "    description = \"Issues a temporary password for a user who has forgotten their credentials.\",\n",
        "    input_schema = {\n",
        "        \"type\": \"object\",\n",
        "        \"properties\": {\n",
        "            \"user_id\": {\"type\": \"string\", \"description\": \"The employee's username or ID.\"}\n",
        "        },\n",
        "        \"required\": [\"user_id\"],\n",
        "    },\n",
        "    handler = _handler_reset_password,\n",
        ")\n",
        "\n",
        "mcp_server.register_tool(\n",
        "    name        = \"unlock_account\",\n",
        "    description = \"Unlocks an account that was locked due to too many failed login attempts.\",\n",
        "    input_schema = {\n",
        "        \"type\": \"object\",\n",
        "        \"properties\": {\n",
        "            \"user_id\": {\"type\": \"string\", \"description\": \"The employee's username or ID.\"}\n",
        "        },\n",
        "        \"required\": [\"user_id\"],\n",
        "    },\n",
        "    handler = _handler_unlock_account,\n",
        ")\n",
        "\n",
        "mcp_server.register_tool(\n",
        "    name        = \"create_ticket\",\n",
        "    description = \"Opens an IT support ticket for issues that cannot be resolved automatically.\",\n",
        "    input_schema = {\n",
        "        \"type\": \"object\",\n",
        "        \"properties\": {\n",
        "            \"summary\":     {\"type\": \"string\", \"description\": \"One-line issue summary.\"},\n",
        "            \"description\": {\"type\": \"string\", \"description\": \"Full issue description.\"},\n",
        "        },\n",
        "        \"required\": [\"summary\", \"description\"],\n",
        "    },\n",
        "    handler = _handler_create_ticket,\n",
        ")\n",
        "\n",
        "mcp_server.register_tool(\n",
        "    name        = \"log_analysis\",\n",
        "    description = \"Fetches IT audit log entries for a user (login_failures, account_changes, mfa_events).\",\n",
        "    input_schema = {\n",
        "        \"type\": \"object\",\n",
        "        \"properties\": {\n",
        "            \"user_id\":  {\"type\": \"string\", \"description\": \"Target username.\"},\n",
        "            \"log_type\": {\n",
        "                \"type\": \"string\",\n",
        "                \"enum\": [\"login_failures\", \"account_changes\", \"mfa_events\"],\n",
        "                \"description\": \"The category of log to retrieve.\",\n",
        "            },\n",
        "        },\n",
        "        \"required\": [\"user_id\", \"log_type\"],\n",
        "    },\n",
        "    handler = _handler_log_analysis,\n",
        ")\n",
        "\n",
        "# ── Print MCP server capabilities ─────────────────────────────────────────────\n",
        "caps = mcp_server.initialize()\n",
        "print(f\"✅ MCP Server initialised  — version {caps['protocolVersion']}\")\n",
        "print(f\"   Server : {caps['serverInfo']['name']} v{caps['serverInfo']['version']}\")\n",
        "print(f\"   Tools  : {len(caps['tools'])} registered\")\n",
        "for t in mcp_server.list_tools():\n",
        "    print(f\"     • {t.name:20s} — {t.description}\")"
      ],
      "id": "MjUAQSjGyonF"
