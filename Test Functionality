        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "#  INTERACTIVE FLOW HANDLERS\n",
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "\n",
        "def _menu_row(num: str, keys: List[str], arrow: str, desc: str) -> None:\n",
        "    \"\"\"Print one menu row with aligned keyword badges and description.\"\"\"\n",
        "    badges = \"  \".join(kw(k) for k in keys)\n",
        "    # Compute visual width so the arrow column lines up regardless of ANSI overhead\n",
        "    badge_vlen = sum(_vlen(kw(k)) for k in keys) + 2 * (len(keys) - 1)\n",
        "    padding    = max(1, 26 - badge_vlen)\n",
        "    print(f\"  {dim(num + '.')}  {badges}{' ' * padding}{DIM}→{RST}  {desc}\")\n",
        "\n",
        "\n",
        "def show_main_menu() -> None:\n",
        "    banner(\"IT Password Reset System\", \"Powered by MCP + LangGraph\")\n",
        "    print(f\"  {DIM}Mode: {LLM_MODE}{RST}\")\n",
        "    section_bar(\"Main Menu  —  type any highlighted keyword\")\n",
        "    _menu_row(\"1\", [\"sign\", \"in\", \"login\"],     \"→\", \"Sign in to your account\")\n",
        "    _menu_row(\"2\", [\"faq\",  \"help\", \"policy\"],  \"→\", \"Policy FAQ & Help\")\n",
        "    _menu_row(\"3\", [\"issue\",\"problem\",\"ticket\"], \"→\", \"Report an issue / contact IT\")\n",
        "    _menu_row(\"4\", [\"exit\", \"quit\"],             \"→\", \"Exit the system\")\n",
        "    print()\n",
        "\n",
        "\n",
        "def show_faq_menu() -> None:\n",
        "    section_bar(\"FAQ  —  type a keyword or number\")\n",
        "    _menu_row(\"1\", [\"temp\"],    \"→\", \"Temporary password rules\")\n",
        "    _menu_row(\"2\", [\"lockout\"], \"→\", \"Account lockout policy\")\n",
        "    _menu_row(\"3\", [\"mfa\"],     \"→\", \"Lost MFA device help\")\n",
        "    _menu_row(\"4\", [\"reuse\"],   \"→\", \"Password reuse policy\")\n",
        "    _menu_row(\"5\", [\"custom\"],  \"→\", \"Ask a custom question\")\n",
        "    _menu_row(\"6\", [\"back\"],    \"→\", \"Return to main menu\")\n",
        "    print()\n",
        "\n",
        "\n",
        "def handle_policy_faqs() -> None:\n",
        "    while True:\n",
        "        show_faq_menu()\n",
        "        choice  = input(f\"  {CYAN}FAQ{RST} > \").strip()\n",
