        "---\n",
        "## 🔀 Section 4 — Workflow Automation: LangGraph Orchestration\n",
        "\n",
        "LangGraph compiles the four agents into a **directed state machine** (DAG).\n",
        "The `route_from_intake` edge function reads `state.intent.top_level` and routes\n",
        "the conversation to the correct agent node — enabling fully automated, branching\n",
        "workflow orchestration.\n",
        "\n",
        "```\n",
        "       [START]\n",
        "          │\n",
        "       [intake]  ─── conditional edge: route_from_intake()\n",
        "        / | \\\n",
        " [knowledge] [workflow] [escalation]\n",
        "       \\    |    /\n",
        "        [END]\n",
        "```\n"
      ],
      "id": "890boYBDyonI"
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "vhj_hE6iyonI",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "6b030806-5b61-493a-a35f-00ba64a5319f"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "✅ LangGraph compiled — agent pipeline ready.\n",
            "   Nodes: intake → [knowledge | workflow | escalation] → END\n",
            "   Workflow can now hand off to escalation when automation fails.\n"
          ]
        }
      ],
      "source": [
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "#  LANGGRAPH — Build, Compile & Runner\n",
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "\n",
        "def route_from_intake(state: GraphState) -> str:\n",
        "    \"\"\"Conditional edge: direct traffic to the correct agent based on intent.\"\"\"\n",
        "    return state.intent.top_level   # \"knowledge\" | \"workflow\" | \"escalation\"\n",
        "\n",
        "\n",
        "def route_after_workflow(state: GraphState) -> str:\n",
        "    \"\"\"If workflow failed, hand off to escalation; otherwise finish.\"\"\"\n",
        "    return \"escalation\" if state.escalation_needed else \"end\"\n",
        "\n",
        "\n",
        "graph = StateGraph(GraphState)\n",
        "\n",
        "graph.add_node(\"intake\",     intake_node)\n",
        "graph.add_node(\"knowledge\",  knowledge_node)\n",
        "graph.add_node(\"workflow\",   workflow_node)\n",
        "graph.add_node(\"escalation\", escalation_node)\n",
        "\n",
        "graph.set_entry_point(\"intake\")\n",
        "graph.add_conditional_edges(\n",
        "    \"intake\",\n",
        "    route_from_intake,\n",
        "    {\"workflow\": \"workflow\", \"knowledge\": \"knowledge\", \"escalation\": \"escalation\"},\n",
        ")\n",
        "graph.add_edge(\"knowledge\", END)\n",
        "graph.add_conditional_edges(\n",
        "    \"workflow\",\n",
        "    route_after_workflow,\n",
        "    {\"escalation\": \"escalation\", \"end\": END},\n",
        ")\n",
        "graph.add_edge(\"escalation\", END)\n",
        "\n",
        "app = graph.compile()\n",
        "\n",
        "\n",
        "# ── Runner ────────────────────────────────────────────────────────────────────\n",
        "def run_agent(\n",
        "    user_query:               str,\n",
        "    user_id:                  str  = \"user123\",\n",
        "    forgot_password_selected: bool = False,\n",
        ") -> GraphState:\n",
        "    \"\"\"Invoke the compiled LangGraph pipeline and return the final GraphState.\"\"\"\n",
        "    init_state = GraphState(\n",
        "        user_query               = user_query,\n",
        "        user_id                  = user_id,\n",
        "        forgot_password_selected = forgot_password_selected,\n",
        "    )\n",
        "    result = app.invoke(init_state)\n",
        "    return GraphState(**result)\n",
        "\n",
        "\n",
        "print(\"✅ LangGraph compiled — agent pipeline ready.\")\n",
        "print(\"   Nodes: intake → [knowledge | workflow | escalation] → END\")\n",
        "print(\"   Workflow can now hand off to escalation when automation fails.\")\n"
      ],
