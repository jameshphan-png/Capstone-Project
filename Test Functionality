        "                print(warn(\"  Please enter a question.\")); continue\n",
        "        elif matched:\n",
        "            query = matched\n",
        "        else:\n",
        "            print(warn(\"  Unrecognised — try: temp, lockout, mfa, reuse, custom, back\"))\n",
        "            continue\n",
        "\n",
        "        result = run_agent(query)\n",
        "        response_box(\"Knowledge Agent\", result.final_response or \"No answer found.\")\n",
        "        trace_box(result.trace, result.mcp_calls)\n",
        "        input(f\"\\n  {GREY}Press Enter to continue…{RST}\")\n",
        "\n",
        "\n",
        "def handle_forgot_password_flow(username: str) -> None:\n",
        "    result = run_agent(\n",
        "        user_query               = \"I forgot my password\",\n",
        "        user_id                  = username,\n",
        "        forgot_password_selected = True,\n",
        "    )\n",
        "    response_box(\"Workflow Agent — Password Reset\", result.final_response or \"\")\n",
        "    trace_box(result.trace, result.mcp_calls)\n",
        "\n",
        "    if not result.temp_password_issued:\n",
        "        input(f\"\\n  {GREY}Press Enter to return to the main menu…{RST}\")\n",
        "        return\n",
        "\n",
        "    MAX_ATTEMPTS = 3\n",
        "    for attempt in range(1, MAX_ATTEMPTS + 1):\n",
        "        print(f\"\\n  {DIM}[TEST HELPER] Temporary password: {result.temp_password_issued}{RST}\")\n",
        "        temp = input(f\"  {CYAN}Temporary password{RST} > \").strip()\n",
        "\n",
        "        if attempt_temp_login(temp):\n",
        "            print(ok(\"\\n  ✔  Temporary password accepted — please set a new password.\"))\n",
        "            section_bar(\"Set New Password\")\n",
        "\n",
        "            while True:\n",
        "                new_pw  = input(f\"  {CYAN}New password    {RST} > \").strip()\n",
        "                conf_pw = input(f\"  {CYAN}Confirm password{RST} > \").strip()\n",
        "\n",
        "                if new_pw != conf_pw:\n",
        "                    print(warn(\"  Passwords do not match — try again.\")); continue\n",
        "                error = validate_new_password(new_pw, result.temp_password_issued or \"\")\n",
        "                if error:\n",
        "                    print(warn(f\"  {error}\")); continue\n",
        "\n",
        "                set_user_password(username, new_pw)\n",
        "                print(ok(\"\\n  ✔  Password updated successfully!\"))\n",
        "                print(f\"  {GREY}You can now sign in with your new password.{RST}\")\n",
        "                input(f\"\\n  {GREY}Press Enter to return to the main menu…{RST}\")\n",
        "                return\n",
        "        else:\n",
        "            remaining = MAX_ATTEMPTS - attempt\n",
        "            if remaining > 0:\n",
        "                print(warn(f\"  ✘  Incorrect temporary password — {remaining} attempt(s) left.\"))\n",
