      "source": [
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "#  UI UTILITIES — clean terminal formatting for Colab / Jupyter\n",
        "#\n",
        "#  Design principle: ANSI escape codes shift string length vs. display width.\n",
        "#  All width calculations use VISIBLE character counts so box-drawing lines up.\n",
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "\n",
        "import re as _re\n",
        "\n",
        "# ── ANSI palette ──────────────────────────────────────────────────────────────\n",
        "RST   = \"\\033[0m\"\n",
        "BOLD  = \"\\033[1m\"\n",
        "DIM   = \"\\033[2m\"\n",
        "CYAN  = \"\\033[96m\"\n",
        "GREEN = \"\\033[92m\"\n",
        "YEL   = \"\\033[93m\"\n",
        "RED   = \"\\033[91m\"\n",
        "BLUE  = \"\\033[94m\"\n",
        "GREY  = \"\\033[90m\"\n",
        "WHITE = \"\\033[97m\"\n",
        "\n",
        "def _strip_ansi(s: str) -> str:\n",
        "    \"\"\"Return string with all ANSI escape sequences removed (for width calc).\"\"\"\n",
        "    return _re.sub(r\"\\033\\[[0-9;]*m\", \"\", s)\n",
        "\n",
        "def _vlen(s: str) -> int:\n",
        "    \"\"\"Visual length — ignores ANSI codes.\"\"\"\n",
        "    return len(_strip_ansi(s))\n",
        "\n",
        "def _pad_to(s: str, width: int, fill: str = \" \") -> str:\n",
        "    \"\"\"Right-pad string to visual `width`, accounting for ANSI overhead.\"\"\"\n",
        "    return s + fill * max(0, width - _vlen(s))\n",
        "\n",
        "# ── Shorthand colourisers ─────────────────────────────────────────────────────\n",
        "def kw(text: str)   -> str: return f\"{CYAN}{BOLD}[{text}]{RST}\"\n",
        "def ok(text: str)   -> str: return f\"{GREEN}{text}{RST}\"\n",
        "def warn(text: str) -> str: return f\"{YEL}{text}{RST}\"\n",
        "def err(text: str)  -> str: return f\"{RED}{text}{RST}\"\n",
        "def bold(text: str) -> str: return f\"{BOLD}{text}{RST}\"\n",
        "def dim(text: str)  -> str: return f\"{DIM}{text}{RST}\"\n",
        "\n",
        "# ── Box / Banner helpers ───────────────────────────────────────────────────────\n",
        "W = 54   # total inner width (between corner characters)\n",
        "\n",
        "def _hline(left: str, fill: str, right: str) -> str:\n",
        "    return f\"{BLUE}{left}{fill * W}{right}{RST}\"\n",
        "\n",
        "def banner(title: str, subtitle: str = \"\") -> None:\n",
        "    print()\n",
        "    print(_hline(\"╔\", \"═\", \"╗\"))\n",
        "    # Use plain strings for .center() so width is exact, then colourise\n",
        "    print(f\"{BLUE}║{RST}{WHITE}{BOLD}{title.center(W)}{RST}{BLUE}║{RST}\")\n",
        "    if subtitle:\n",
        "        print(f\"{BLUE}║{RST}{DIM}{subtitle.center(W)}{RST}{BLUE}║{RST}\")\n",
        "    print(_hline(\"╚\", \"═\", \"╝\"))\n",
        "\n",
        "def section_bar(label: str) -> None:\n",
        "    dashes = \"─\" * max(0, W - len(label) - 2)\n",
        "    print(f\"\\n{DIM}──  {label}  {dashes}{RST}\")\n",
        "\n",
        "def response_box(label: str, content: str) -> None:\n",
        "    top_fill = \"─\" * max(0, W - len(label) - 4)\n",
        "    print(f\"\\n{BLUE}┌── {label} {top_fill}┐{RST}\")\n",
        "    for line in content.strip().split(\"\\n\"):\n",
        "        print(f\"{BLUE}│{RST}  {line}\")\n",
        "    print(f\"{BLUE}└{'─' * W}┘{RST}\")\n",
        "\n",
        "def trace_box(trace: List[str], mcp_calls: \"List[Any]\") -> None:\n",
        "    print(f\"\\n{DIM}{'·' * (W + 2)}{RST}\")\n",
        "    print(f\"{DIM}  Agent trace{RST}\")\n",
        "    for step in trace:\n",
        "        print(f\"  {GREY}{step}{RST}\")\n",
        "    if mcp_calls:\n",
        "        print(f\"{DIM}  MCP calls{RST}\")\n",
        "        for c in mcp_calls:\n",
        "            icon = ok(\"✔\") if c.success else err(\"✘\")\n",
        "            name = f\"{BOLD}{c.tool_name}{RST}\"\n",
        "            print(f\"  {icon}  {_pad_to(name, 28)}  {GREY}{c.summary[:46]}{RST}\")\n",
        "    print(f\"{DIM}{'·' * (W + 2)}{RST}\")\n",
        "\n",
        "# ── Menu keyword matchers ─────────────────────────────────────────────────────\n",
        "def _norm(text: str) -> str:\n",
        "    return text.strip().lower()\n",
        "\n",
        "def match_main_menu(text: str) -> Optional[str]:\n",
        "    t = _norm(text)\n",
        "    if t in {\"1\",\"sign\",\"in\",\"sign in\",\"signin\",\"sign-in\",\"login\",\"log in\",\"logon\"}:\n",
        "        return \"sign_in\"\n",
        "    if t in {\"2\",\"faq\",\"help\",\"policy\",\"policies\",\"guide\"}:\n",
        "        return \"faq\"\n",
        "    if t in {\"3\",\"issue\",\"problem\",\"support\",\"ticket\",\"question\",\"contact\"}:\n",
        "        return \"issue\"\n",
        "    if t in {\"4\",\"exit\",\"quit\",\"q\",\"bye\",\"close\",\"leave\"}:\n",
        "        return \"exit\"\n",
        "    return None\n",
        "\n",
        "def match_yes_no(text: str) -> Optional[bool]:\n",
        "    t = _norm(text)\n",
        "    if t in {\"yes\",\"y\",\"yeah\",\"yep\",\"sure\",\"ok\"}:  return True\n",
        "    if t in {\"no\",\"n\",\"nope\",\"nah\"}:               return False\n",
        "    return None\n",
        "\n",
        "def match_faq_choice(text: str) -> Optional[str]:\n",
