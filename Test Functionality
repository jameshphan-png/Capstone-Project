        "---\n",
        "## Section 3c — Workflow Agent\n",
        "\n",
        "**Role:** Executes IT automation actions via MCP tool calls.\n",
        "For each workflow intent (`forgot_password`, `account_locked`) it:\n",
        "1. Retrieves relevant policy context (RAG)\n",
        "2. Calls the appropriate MCP tool\n",
        "3. If the workflow fails, marks the case for escalation\n",
        "\n",
        "**Fallback rules:** escalate when:\n",
        "- the workflow fails\n",
        "- the issue is unclear\n",
        "- the request is out of scope\n",
        "\n",
        "**Outputs:** workflow results on success, or escalation flags that route the user to the Escalation Agent.\n"
      ],
      "id": "jkTXqmDeyonH"
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "zQUTd-EUyonI",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "efa50b97-7768-45d2-b107-a2ece0283e73"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "✅ Workflow Agent defined.\n"
          ]
        }
      ],
      "source": [
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "#  WORKFLOW AGENT — MCP Tool Execution & Automation\n",
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "\n",
        "def _mcp_call(tool_name: str, **kwargs) -> Tuple[MCPToolResult, Dict[str, Any]]:\n",
        "    \"\"\"\n",
        "    Helper: build an MCPToolCallRequest, call the MCP server, return (result, raw_json).\n",
        "    Logs every call to the MCP audit trail.\n",
        "    \"\"\"\n",
        "    request = MCPToolCallRequest(tool_name=tool_name, arguments=kwargs)\n",
        "    result  = mcp_server.call_tool(request)\n",
        "    raw     = json.loads(result.content[0].text) if not result.is_error else {}\n",
        "    return result, raw\n",
        "\n",
        "\n",
        "def _tool_log(result: MCPToolResult, summary: str) -> ToolCallLog:\n",
        "    return ToolCallLog(\n",
        "        call_id   = result.call_id,\n",
        "        tool_name = result.tool_name,\n",
        "        success   = not result.is_error,\n",
        "        summary   = summary,\n",
        "    )\n",
        "\n",
        "\n",
        "def workflow_node(state: GraphState) -> Dict[str, Any]:\n",
        "    \"\"\"\n",
        "    WORKFLOW AGENT — Automates IT actions using MCP tools.\n",
        "\n",
        "    Simple escalation rule:\n",
        "      - if workflow fails\n",
        "      - or issue is unclear\n",
        "      - or the request is out of scope\n",
        "      → escalate\n",
        "    \"\"\"\n",
        "    user_id    = state.user_id or VALID_USER\n",
        "    mcp_calls: List[ToolCallLog] = []\n",
        "\n",
        "    # ── Log Analysis (always runs for workflow intents) ────────────────────────\n",
        "    log_result, log_data = _mcp_call(\"log_analysis\", user_id=user_id,\n",
        "                                     log_type=\"login_failures\")\n",
        "    mcp_calls.append(_tool_log(\n",
        "        log_result,\n",
        "        f\"Fetched {log_data.get('count', '?')} login-failure log entries for {user_id}\"\n",
        "    ))\n",
        "\n",
        "    # ── Forgot Password ────────────────────────────────────────────────────────\n",
        "    if state.intent.label == \"forgot_password\":\n",
        "        retrieved = _retrieve_policy_docs(\"forgot password temporary password reset\")\n",
        "\n",
        "        reset_result, reset_data = _mcp_call(\"reset_password\", user_id=user_id)\n",
        "        mcp_calls.append(_tool_log(reset_result, reset_result.content[0].text[:80]))\n",
        "\n",
        "        if not reset_result.is_error:\n",
        "            temp_pw = reset_data.get(\"temp_password\", TEMP_PASSWORD)\n",
        "            return {\n",
        "                \"retrieved_context\":    retrieved,\n",
        "                \"mcp_calls\":            mcp_calls,\n",
        "                \"temp_password_issued\": temp_pw,\n",
        "                \"final_response\": (\n",
        "                    \"✅ Password reset successful.\\n\"\n",
        "                    \"A temporary password has been issued.\\n\"\n",
        "                    \"Please sign in with it and change it immediately.\"\n",
        "                ),\n",
        "                \"trace\": state.trace + [\n",
        "                    f\"[workflow] reset_password → success for {user_id}\",\n",
        "                    f\"[workflow] log_analysis   → {log_data.get('count', '?')} entries\",\n",
        "                ],\n",
        "            }\n",
        "\n",
        "        return {\n",
        "            \"retrieved_context\":   retrieved,\n",
        "            \"mcp_calls\":           mcp_calls,\n",
        "            \"escalation_needed\":   True,\n",
        "            \"escalation_reason\":   \"workflow_failed\",\n",
        "            \"trace\": state.trace + [\n",
        "                f\"[workflow] reset_password → failed for {user_id}\",\n",
        "                \"[workflow] fallback rule triggered → escalate\",\n",
        "            ],\n",
        "        }\n",
        "\n",
        "    # ── Account Locked ─────────────────────────────────────────────────────────\n",
        "    if state.intent.label == \"account_locked\":\n",
        "        retrieved = _retrieve_policy_docs(\"account lockout unlock procedure policy\")\n",
        "\n",
        "        unlock_result, _unlock_data = _mcp_call(\"unlock_account\", user_id=user_id)\n",
        "        mcp_calls.append(_tool_log(unlock_result, unlock_result.content[0].text[:80]))\n",
        "\n",
        "        if not unlock_result.is_error:\n",
        "            return {\n",
        "                \"retrieved_context\":     retrieved,\n",
        "                \"mcp_calls\":             mcp_calls,\n",
        "                \"login_access_restored\": True,\n",
        "                \"final_response\": (\n",
        "                    \"✅ Account unlocked successfully.\\n\"\n",
        "                    \"You may now attempt to sign in again with your password.\"\n",
        "                ),\n",
        "                \"trace\": state.trace + [\n",
        "                    f\"[workflow] unlock_account → success for {user_id}\",\n",
        "                ],\n",
        "            }\n",
        "\n",
        "        return {\n",
        "            \"retrieved_context\":   retrieved,\n",
        "            \"mcp_calls\":           mcp_calls,\n",
        "            \"escalation_needed\":   True,\n",
        "            \"escalation_reason\":   \"workflow_failed\",\n",
        "            \"trace\": state.trace + [\n",
        "                f\"[workflow] unlock_account → failed for {user_id}\",\n",
        "                \"[workflow] fallback rule triggered → escalate\",\n",
        "            ],\n",
        "        }\n",
        "\n",
        "    # ── Unsupported workflow → out of scope ───────────────────────────────────\n",
        "    return {\n",
        "        \"mcp_calls\":           mcp_calls,\n",
        "        \"escalation_needed\":   True,\n",
        "        \"escalation_reason\":   \"out_of_scope\",\n",
        "        \"trace\": state.trace + [\n",
        "            \"[workflow] unsupported request → escalate\",\n",
        "        ],\n",
        "    }\n",
        "\n",
        "\n",
        "print(\"✅ Workflow Agent defined.\")\n"
      ],
      "id": "zQUTd-EUyonI"
