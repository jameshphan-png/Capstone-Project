      "source": [
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "#  PYDANTIC MODELS — typed state shared across all agents\n",
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "\n",
        "class RetrievedDoc(BaseModel):\n",
        "    \"\"\"A policy document chunk returned by the RAG retriever.\"\"\"\n",
        "    title:   str\n",
        "    snippet: str\n",
        "    source:  str = \"policy\"\n",
        "\n",
        "\n",
        "class Intent(BaseModel):\n",
        "    \"\"\"The structured output of the Intake Agent's classification step.\"\"\"\n",
        "    top_level:  Literal[\"knowledge\", \"workflow\", \"escalation\"] = \"escalation\"\n",
        "    label:      Literal[\n",
        "                    \"forgot_password\", \"account_locked\",\n",
        "                    \"mfa_help\", \"policy_question\", \"escalate\"\n",
        "                ] = \"escalate\"\n",
        "    confidence: float = 0.0\n",
        "\n",
        "\n",
        "class ToolCallLog(BaseModel):\n",
        "    \"\"\"A record of an MCP tool invocation stored in the shared state.\"\"\"\n",
        "    call_id:   str\n",
        "    tool_name: str\n",
        "    success:   bool\n",
        "    summary:   str\n",
        "\n",
        "\n",
        "class GraphState(BaseModel):\n",
        "    \"\"\"\n",
        "    Shared blackboard passed through every LangGraph node.\n",
        "    Each agent reads what it needs and writes partial updates back.\n",
        "    \"\"\"\n",
        "    # ── Input ─────────────────────────────────────────────────────────────────\n",
        "    user_query:               str             = \"\"\n",
        "    user_id:                  Optional[str]   = None\n",
        "    forgot_password_selected: bool            = False\n",
        "\n",
        "    # ── Intake Agent outputs ──────────────────────────────────────────────────\n",
        "    intent:                   Intent          = Field(default_factory=Intent)\n",
        "\n",
        "    # ── Knowledge Agent outputs ───────────────────────────────────────────────\n",
        "    retrieved_context:        List[RetrievedDoc] = Field(default_factory=list)\n",
        "\n",
        "    # ── Workflow Agent outputs ────────────────────────────────────────────────\n",
        "    mcp_calls:                List[ToolCallLog]  = Field(default_factory=list)\n",
        "    temp_password_issued:     Optional[str]      = None\n",
        "    login_access_restored:    bool               = False\n",
        "    escalation_needed:        bool               = False\n",
        "    escalation_reason:        Optional[str]      = None\n",
        "    ticket_id:                Optional[str]      = None\n",
        "\n",
        "    # ── Shared outputs ────────────────────────────────────────────────────────\n",
        "    final_response:           Optional[str]      = None\n",
        "    trace:                    List[str]          = Field(default_factory=list)\n",
        "\n",
        "\n",
        "print(\"✅ Pydantic state models defined.\")\n"
      ],
