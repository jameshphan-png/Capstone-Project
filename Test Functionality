        "---\n",
        "## Section 3b — Knowledge Agent\n",
        "\n",
        "**Role:** Answers policy and guidance questions using RAG retrieval.\n",
        "Retrieves the top-3 most relevant policy chunks from the knowledge base and\n",
        "either feeds them into an LLM prompt (OpenAI mode) or renders a deterministic\n",
        "natural-language answer (BM25 mode).\n",
        "\n",
        "**Outputs:** `retrieved_context` (list of `RetrievedDoc`) and `final_response`.\n"
      ],
      "id": "Jn6R0FmkyonH"
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "G5fJnba-yonH",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "6f09a876-8df1-4762-e045-daca7c6b0a6f"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "✅ Knowledge Agent defined.\n"
          ]
        }
      ],
      "source": [
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "#  KNOWLEDGE AGENT — RAG-Powered Policy Q&A\n",
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "\n",
        "def _retrieve_policy_docs(query: str) -> List[RetrievedDoc]:\n",
        "    \"\"\"Invoke the RAG retriever and return structured RetrievedDoc objects.\"\"\"\n",
        "    docs = kb_retriever.invoke(query)\n",
        "    return [\n",
        "        RetrievedDoc(\n",
        "            title   = d.metadata.get(\"title\", \"policy_doc\"),\n",
        "            snippet = d.page_content[:350],\n",
        "            source  = d.metadata.get(\"source\", \"policy\"),\n",
        "        )\n",
        "        for d in docs\n",
        "    ]\n",
        "\n",
        "\n",
        "def _render_bm25_answer(user_query: str, retrieved: List[RetrievedDoc]) -> str:\n",
        "    \"\"\"Deterministic answer renderer for BM25 mode (no LLM needed).\"\"\"\n",
        "    if not retrieved:\n",
        "        return \"I couldn't find that in the current policy documents.\"\n",
        "\n",
        "    top     = retrieved[0]\n",
        "    snippet = top.snippet.lower()\n",
        "    q       = user_query.lower()\n",
        "\n",
        "    if \"temporary password\" in snippet or \"temp password\" in q:\n",
        "        answer = (\n",
        "            \"After signing in with a temporary password, you must change it \"\n",
        "            \"immediately to a new secure password. Temporary passwords are \"\n",
        "            \"single-use and cannot be reused as your permanent credential.\"\n",
        "        )\n",
        "    elif \"failed login\" in snippet or \"lockout\" in snippet or \"locked\" in q:\n",
        "        answer = (\n",
        "            \"Accounts are locked after 5 failed login attempts within 15 minutes. \"\n",
        "            \"The lockout lasts 15 minutes, after which you may try again, or contact \"\n",
        "            \"IT support for a manual unlock.\"\n",
        "        )\n",
        "    elif \"mfa\" in snippet or \"multi-factor\" in snippet or \"authenticator\" in snippet:\n",
        "        answer = (\n",
        "            \"If you lose your MFA device, contact IT support immediately for an MFA \"\n",
        "            \"reset. After the reset you will need to re-enroll a new device at your \"\n",
        "            \"next login. Supported second factors: Authenticator App, SMS, Hardware Token.\"\n",
        "        )\n",
        "    else:\n",
        "        answer = top.snippet.strip().replace(\"\\n\", \" \")\n",
        "        if len(answer) > 320:\n",
        "            answer = answer[:320] + \"…\"\n",
        "\n",
        "    return f\"{answer}\\n\\n📄 Source: {top.title}\"\n",
        "\n",
        "\n",
        "def knowledge_node(state: GraphState) -> Dict[str, Any]:\n",
        "    \"\"\"\n",
        "    KNOWLEDGE AGENT — Retrieves policy context and formulates a grounded answer.\n",
        "\n",
        "    Collaboration: Reads 'user_query' and 'intent'; writes 'retrieved_context',\n",
        "                   'final_response', and 'trace' back to GraphState.\n",
        "    \"\"\"\n",
        "    retrieved = _retrieve_policy_docs(state.user_query)\n",
        "\n",
        "    if USE_OPENAI or USE_FREE_LLM:\n",
        "        context_text = \"\\n\\n\".join(f\"[{d.title}]\\n{d.snippet}\" for d in retrieved)\n",
        "        prompt = ChatPromptTemplate.from_template(\n",
        "            \"\"\"You are an IT knowledge agent.\n",
        "Answer using ONLY the retrieved context below. Be concise and practical.\n",
        "If the answer isn't in the context, say so. Cite source title at the end.\n",
        "\n",
        "Question: {question}\n",
        "\n",
        "Context:\n",
        "{context}\"\"\"\n",
        "        )\n",
        "        answer          = (prompt | llm).invoke({\"question\": state.user_query, \"context\": context_text})\n",
        "        final_response  = answer.content\n",
        "    else:\n",
        "        final_response  = _render_bm25_answer(state.user_query, retrieved)\n",
        "\n",
        "    return {\n",
        "        \"retrieved_context\": retrieved,\n",
        "        \"final_response\":    final_response,\n",
