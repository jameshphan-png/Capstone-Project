        "\n",
        "def chat(message, history, user_id, temp_pw_state, verified_state):\n",
        "    \"\"\"\n",
        "    Main Helpdesk Chat handler.\n",
        "\n",
        "    Important behavior:\n",
        "    - general policy/help questions still go through the existing agent\n",
        "    - password-reset requests are blocked until identity verification succeeds\n",
        "    - once verified, the agent may issue a temporary password and the Password\n",
        "      Change Portal is automatically updated\n",
        "    \"\"\"\n",
        "    if not message.strip():\n",
        "        return history, history, \"—\", \"—\", \"—\", \"—\", temp_pw_state, \"Not yet issued — request one in 💬 Helpdesk Chat first.\"\n",
        "\n",
        "    if _looks_like_password_reset_request(message) and not verified_state:\n",
        "        response = (\n",
        "            \"🔒 Before IT can assign a temporary password, please complete the \"\n",
        "            \"**Identity Verification** panel on the right side of the Helpdesk Chat tab.\\n\\n\"\n",
        "            \"Required checks in this demo:\\n\"\n",
        "            \"• 6-digit employee ID\\n\"\n",
        "            \"• company email\\n\"\n",
        "            \"• supported MFA method\\n\"\n",
        "            \"• 6-digit verification code\"\n",
        "        )\n",
        "        history = history + [[message, response]]\n",
        "        return (\n",
        "            history,\n",
        "            history,\n",
        "            \"SECURITY  /  verification_required\\nConfidence: 100%\",\n",
        "            \"0.00s\",\n",
        "            \"No MCP tools called — request blocked until identity verification succeeds.\",\n",
        "            \"→ Helpdesk Chat\\n→ Security gate: password reset blocked pending identity verification\",\n",
        "            temp_pw_state,\n",
        "            temp_pw_state or \"Not yet issued — request one in 💬 Helpdesk Chat first.\",\n",
        "        )\n",
        "\n",
        "    uid = user_id.strip() or \"user123\"\n",
        "    t0 = time.time()\n",
        "    result = run_agent(message, user_id=uid, forgot_password_selected=False)\n",
        "    elapsed = time.time() - t0\n",
        "\n",
        "    response = result.final_response or \"No response generated.\"\n",
        "    new_temp_pw_state = temp_pw_state\n",
        "    temp_display = temp_pw_state or \"Not yet issued — request one in 💬 Helpdesk Chat first.\"\n",
        "\n",
        "    if result.temp_password_issued:\n",
        "        new_temp_pw_state = result.temp_password_issued\n",
        "        temp_display = result.temp_password_issued\n",
        "        response = (\n",
        "            \"✅ Password reset successful.\\n\\n\"\n",
        "            \"Your identity verification has been accepted and IT has issued a temporary password.\\n\\n\"\n",
        "            f\"🔑 **Temporary password: `{result.temp_password_issued}`**\\n\"\n",
        "            \"Please go to the **🔄 Password Change Portal** tab and change it immediately after sign-in.\"\n",
        "        )\n",
        "\n",
        "    history = history + [[message, response]]\n",
